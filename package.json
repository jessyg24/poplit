{
  "name": "poplit",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "turbo run dev --filter=@poplit/web",
    "dev:mobile": "turbo run dev --filter=@poplit/mobile",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "dependencies": {
    "next": "15.3.0"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "overrides": {
    "@types/react": "^19.0.0"
  }
}
